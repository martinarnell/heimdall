# Heimdall environment variables
# Copy to .env and fill in values as needed.

# ── LINZ Data Service (New Zealand addresses) ─────────────────────────
# Free account: https://data.linz.govt.nz/
# Create API key: My Account → API Keys → Create Key (with query scope)
LINZ_API_KEY=

# ── Lantmäteriet (Swedish addresses) ──────────────────────────────────
# Requires a Lantmäteriet developer account with Belägenhetsadress access
LM_USER=
LM_PASS=
