# Build artifacts
/target
.DS_Store

# ── Environment (secrets) ───────────────────────────────────────────
.env

# ── Data downloads (large, user-specific) ─────────────────────────────
/data/osm/
/data/downloads/
/data/photon/
/data/photon-gb/
/data/denmark/
/data/norway/
/data/lm_*/

# ── Built indices (generated by heimdall-build) ───────────────────────
/data/index-*/

# ── Rebuild pipeline state ────────────────────────────────────────────
data/rebuild-state.json
data/rebuild-report-*.log

# ── Intermediate build artifacts ──────────────────────────────────────
*.parquet
*.pbf
*.zip
*.tar.bz2

# ── Benchmark / comparison artifacts ──────────────────────────────────
/data/benchmarks/
data/bench-results*.csv
data/bench-queries.txt
data/lm_urls.txt

# ── Development notes (internal, not for release) ────────────────────
/notes/

# ── Release packages ─────────────────────────────────────────────────
/dist/

# ── Rebuild logs ─────────────────────────────────────────────────────
rebuild*.log

# ── Global data cache ────────────────────────────────────────────────
/data/global/

# ── Stray config copies ──────────────────────────────────────────────
/sv.toml

# ── Local dev notes ──────────────────────────────────────────────────
/CLAUDE.local.md
data/index-se-dev

# ── Claude Code per-machine state ────────────────────────────────────
/.claude/

# ── Local symlinks for dev workflow (machine-specific, would break elsewhere) ──
/data-test/
/data/data
/data/data-dev/

# ── Top-level benchmark artefacts (large, regen via heimdall-compare) ─
# Ignore directory contents but allow exceptions below for pinned baselines
# (must use /benchmarks/* not /benchmarks/ — directory-level ignores prevent
# git from entering the directory at all, breaking the negations).
/benchmarks/*
# Pinned baselines committed deliberately as regression references.
# Add new entries here when you pin another corpus.
!/benchmarks/us-queries-190-seed42.jsonl
!/benchmarks/us-baseline-pre-parity.sqlite
!/benchmarks/us-baseline-pre-parity.md
