FROM rust:1.88-bookworm AS builder
RUN apt-get update && \
    apt-get install -y --no-install-recommends cmake clang && \
    rm -rf /var/lib/apt/lists/*
WORKDIR /build
COPY . .
RUN cargo build --release -p heimdall-build

FROM debian:bookworm-slim
RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates curl jq bzip2 && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /work
COPY --from=builder /build/target/release/heimdall-build /usr/local/bin/heimdall-build
COPY data/sources.toml /work/data/sources.toml
COPY data/normalizers /work/data/normalizers
COPY crates/heimdall-build/tests/phase4_e2e.sh /usr/local/bin/phase4_e2e.sh
RUN chmod +x /usr/local/bin/phase4_e2e.sh

ENTRYPOINT ["/usr/local/bin/phase4_e2e.sh"]
